{
  "name": "search100x",
  "version": "2.2.0",
  "description": "Multi-source web search for LLM grounding — works with any model provider",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "search100x": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "npm run build && node --test tests/*.test.js",
    "dev": "tsc --watch"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "search",
    "web-search",
    "llm",
    "llm-grounding",
    "rag",
    "ai-agent",
    "langchain",
    "vercel-ai",
    "claude",
    "openai",
    "sarvam",
    "hermes",
    "legal",
    "india-legal",
    "rrf",
    "bm25",
    "citations",
    "brave",
    "tavily",
    "wikipedia"
  ],
  "author": "Rahul - Dharmabot AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdvRahulAR/search100x.git"
  },
  "homepage": "https://github.com/AdvRahulAR/search100x#readme",
  "bugs": {
    "url": "https://github.com/AdvRahulAR/search100x/issues"
  },
  "dependencies": {
    "node-html-parser": "^6.1.0"
  },
  "optionalDependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
